<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wedding-----Planner</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="/chatbot.css">
</head>

<body>

<header class="head"> 
 
        <nav class="navbar ">
        <div>
            <a href="#" class="active">Home</a>
        <a href="#service">Service</a>
        <a href="#vendor">Prices</a>
        <a href="#venue">Venue</a>
        <a href="#invite">E-invites</a>
        <a href="#contact">Contact</a>
        <a href="/login">Login</a>
        <a href = "/signup">SignUp</a>
        <% if (isAdmin) { %>
          <a href="/admin">Admin Panel</a>
        <% } %>
        </div>
        </nav>
        <div id="menu-bar"><i class="fas fa-bars"></i></div> 
    </header>


    <!--Home-->
    <section class="home" id="home" style="background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.4)), url('/images/bg/background.webp'); background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    justify-content: center;
    align-items: center;
    height: 80vh;">

        <form action="/index0">
            <div class="search-box" >
                <h1> ABG WEDDINGS</h1>
                <p> Best wedding vendors with thousands of trusted reviews</p>
                <button class="btn"><a href = "/login">Login</a></button>
                <button class="btn"><a href="/signup">SignUp</a></button>
                
        </form>
    </section>
    <section class="service" id="service">
        <div class="title">
            <h1><span>S</span>ervice</h1>
        </div>
        <div class="services-row">
            <% services.forEach(function(service) { %>
                <div class="services-col service-card" data-service-title="<%= service.title %>">
                    <% if(service.title.toLowerCase() === 'flowers'){ %>
    <i class="fas fa-spa"></i>
<% } else { %>
    <i class="<%= service.iconClass %>"></i>
<% } %>
                    <h2 class="service-title"><%= service.title %></h2>
                    <p><%= service.description %></p>
                </div>
            <% }) %>
        </div>
    </section>

    <div id="serviceModal" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal('serviceModal')">&times;</span>
            <h2 id="serviceModalTitle">Service Gallery</h2>
            <div id="serviceModalGallery" class="modal-gallery"></div>
        </div>
    </div>

    <!--vendor-->
    <section class="vendor" id="vendor">
        <div class="title">
            <h1><span>S</span>ervice <span>P</span>rices</h1>
        </div>
        <div class="vendor-list">
            <div class="vendor-row">
                <img src="/images/bg/make.jpg" alt="img">
                <h2>Beauty & Makeup</h2>
                <p>Beauty & Makeup</p>
               <h3>RS.30,000 onwards</h3>
            </div>
            <div class="vendor-row">              
                <img src="/images/bg/im1.jpg" alt="img">
                <h2> jewellery</h2>
                <p>Wedding jewellery</p>
                <h3>RS.1-2 Lakh</h3>
            </div>
            <div class="vendor-row">
                <img src="/images/bg/img3.jpg" alt="img">
                <h2>Photography & Video</h2>
                <p>Wedding shoot</p>
                <h3>RS.30,000 onwards </h3>
            </div>
            <div class="vendor-row">
                <img src="/images/bg/food.jpg" alt="img">
                <h2>cooking & Catering</h2>
                <p>Food  catering</p>
                <h3>RS.70,000 onwards</h3>
            </div>
            <div class="vendor-row">
                <img src="/images/bg/flower.jpg" alt="img">
                <h2>Wedding flowers</h2>
                <p>Wedding Decorators</p>
                <h3>RS.25,000 onwards</h3>
            </div>
            <div class="vendor-row">
                <img src="/images/bg/dance.jpg" alt="img">
                <h2>music band & DJ</h2>
                <p>Entertainment</p>
                <h3>RS.20,000 onwards</h3>  
            </div>
        </div>
    </section>

    <!---venue Section-->
    <section class="venue" id="venue">
        <div class="title">
            <h1><span>V</span>enues</h1>
        </div>
        <div class="venue-list">
            <div class="venue-box">
                <img src="/images/venues/zGoa.jpg" alt="img">
                <div class="venue-info">
                    <h2>Goa</h2>
                    <p>RS. 25,000 onwards</p>
                </div>
            </div>
            <div class="venue-box">
                <img src="/images/venues/zkerala.jpeg" alt="img" class="thumbnail" id="main-photo">
                <div class="venue-info">
                    <h2>Kerala</h2>
                    <p>RS. 20,000 onwards</p>
                </div>
            </div>
            <div class="venue-box">
                <img src="/images/venues/zdelhi.jpg" alt="img">
                <div class="venue-info">
                    <h2>Delhi</h2>
                    <p>RS. 40,000 onwards</p>
                </div>
            </div>
            <div class="venue-box">
                <img src="/images/venues/zJaipur.jpg" alt="img">
                <div class="venue-info">
                    <h2>Jaipur</h2>
                    <p>RS. 30,000 onwards</p>
                </div>
            </div>
            <div class="venue-box">
                <img src="/images/venues/zvijayawada.jpeg" alt="img">
                <div class="venue-info">
                    <h2>Vijayawada</h2>
                    <p>RS. 35,000 onwards</p>
                </div>
            </div>
            <div class="venue-box">
                <img src="/images/venues/zmumbai.jpeg" alt="img">
                <div class="venue-info">
                    <h2>Mumbai</h2>
                    <p>RS.30,000 onwards</p>
                </div>
            </div>
        </div>

        <!-- "More" Button -->
        <div class="more-btn-container">
            <a href = "/login"><button class="btn" id="showMoreBtn">Show More Venues</button></a>
        </div>
    </section>   
        <!--E-invitation-->
    <section class="invite" id="invite">
        <div class="title">
            <h1>Card<span>Designs</span></h1>
            
        </div>
        <div class="invitation-row">
            <div class="invitation-box">
                <img src="/images/cards/card-1.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-2.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-3.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-4.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-5.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-6.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-7.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-8.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-9.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-10.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-11.jpg" alt="">
            </div>
            <div class="invitation-box">
                <img src="/images/cards/card-12.jpg" alt="">
            </div>
        </div>

        <!-- "More" Button -->
        <div class="more-btn-container1">
           <a href = "/login"><button class="btn1" id="showMoreBtn1">Show More Venues</button></a>
        </div>
    </section>

    <section class="reviews" id="reviews">
        <div class="title">
            <h1><span>C</span>ustomer <span>R</span>eviews</h1>
        </div>
        <div class="review-summary">
            <div class="review-stars"><%= reviewRatingStars || '★★★★★' %></div>
            <h2>Rated <%= averageRating || 5 %>/5 by our customers</h2>
            <p class="review-count"><%= reviewCount || 0 %> reviews</p>
            <button id="viewReviewsBtn" class="btn review-button">View Reviews</button>
        </div>

        <div id="reviewModal" class="review-modal">
            <div class="review-modal-content">
                <span id="reviewModalClose" class="close-btn">&times;</span>
                <h2>Customer Reviews</h2>
                <div class="review-list">
                    <% if (reviews.length === 0) { %>
                        <p>No reviews yet. Be the first to post one!</p>
                    <% } else { %>
                        <% reviews.forEach(function(review) { %>
                            <div class="review-item">
                                <div class="review-header">
                                    <strong><%= review.name %></strong>
                                    <span><%= '★'.repeat(review.rating || 5) %><%= '☆'.repeat(5 - (review.rating || 5)) %></span>
                                </div>
                                <p><%= review.text %></p>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
                <% if (userName) { %>
                    <form action="/reviews" method="post" class="review-form">
                        <input type="text" name="name" placeholder="Your Name" value="<%= userName || '' %>" required>
                        <div class="rating-input">
                            <input type="radio" id="star5" name="rating" value="5" checked>
                            <label for="star5">★</label>
                            <input type="radio" id="star4" name="rating" value="4">
                            <label for="star4">★</label>
                            <input type="radio" id="star3" name="rating" value="3">
                            <label for="star3">★</label>
                            <input type="radio" id="star2" name="rating" value="2">
                            <label for="star2">★</label>
                            <input type="radio" id="star1" name="rating" value="1">
                            <label for="star1">★</label>
                        </div>
                        <textarea name="text" rows="4" placeholder="Write your review" required></textarea>
                        <button class="btn" type="submit">Post Review</button>
                    </form>
                <% } else { %>
                    <p class="review-login-message">Please <a href="/login">login</a> to post a review.</p>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Booking Modal -->
    <div id="bookingModal" class="booking-modal">
        <div class="booking-modal-content">
            <span id="bookingModalClose" class="booking-close">&times;</span>
            <h2>Book <span id="selectedService"></span></h2>
            <form id="bookingForm" class="booking-form">
                <input type="hidden" id="serviceId" name="serviceId">
                <input type="hidden" id="serviceName" name="serviceName">
                
                <div class="form-group">
                    <label for="eventDate">Wedding Date:</label>
                    <input type="date" id="eventDate" name="eventDate">
                </div>
                
                <div class="form-group">
                    <label for="notes">Additional Notes:</label>
                    <textarea id="notes" name="notes" rows="4" placeholder="Any special requests or information..."></textarea>
                </div>
                
                <% if (userName) { %>
                    <button type="submit" class="booking-submit">Confirm Booking</button>
                <% } else { %>
                    <p style="color: #666; text-align: center; padding: 1rem;">Please <a href="/login" style="color: var(--clr2);">login</a> to book services</p>
                <% } %>
            </form>
        </div>
    </div>

    <section class="stats-section">
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value" data-target="<%= stats?.totalBookings || 2000 %>"><%= stats?.totalBookings || 2000 %></div>
                <p>Total Booking Customers</p>
            </div>
            <div class="stat-card">
                <div class="stat-value" data-target="<%= stats?.customersVisited || 5000 %>"><%= stats?.customersVisited || 5000 %></div>
                <p>Customers Visited Site</p>
            </div>
            <div class="stat-card">
                <div class="stat-value" data-target="<%= stats?.successfulEvents || 1500 %>"><%= stats?.successfulEvents || 1500 %></div>
                <p>Successfully Completed Events</p>
            </div>
            <div class="stat-card">
                <div class="stat-value" data-target="<%= stats?.ongoingEvents || 300 %>"><%= stats?.ongoingEvents || 300 %></div>
                <p>Ongoing Events</p>
            </div>
        </div>
    </section>

    <!--footer section-->
    <footer id="contact">
        <div class="container">
            <div class="f-container">
                <h2>ABG Weddings - Your Personal Wedding Planner</h2><br>
                <p>Plan your wedding with Us ABG Weddings is an Indian Wedding Planning Website </p>
                <div>
                    <button class="btn"><a href="#home">Register as a Vendor</a></button>
                </div>
                <div class="social">
                    <i class="fab fa-facebook"></i>
                    <i class="fab fa-instagram"></i>
                    <i class="fab fa-linkedin"></i>
                    <i class="fab fa-twitter"></i>
                    <i class="fab fa-pinterest"></i>
                </div>
                
            </div>
            <div class="f-container">
                    <h2>About Us</h2>
                    <p>We Will Be Give Our Best For FullFill Your Dreams </p>
                    <h2>Our Love</h2>
					<p>Our love is built on a foundation of trust, respect, and unwavering support for one another. Together, we've navigated life's ups and downs, always standing by each other's side.
                    </p>
            </div>
                    
            <div class = "f-container">
           			<h2>Contact Us</h2><br>
            		<h2><b>nrk123786@gmail.com</b></h2>
            		<h2><b>8309607825</b></h2>
            </div>
        
        </div>
    </footer>
    <!-- Chatbot widget -->
    <div class="chatbot">
        <button id="chatToggle" class="chatbot-button" aria-label="Open chat"><i class="fas fa-comments"></i></button>
        <div id="chatWindow" class="chat-window hidden" aria-hidden="true">
            <div class="chat-header">
                <span>Help Center</span>
                <button id="chatClose" class="chat-close" aria-label="Close chat">&times;</button>
            </div>
            <div id="chatMessages" class="chat-messages" role="log" aria-live="polite"></div>
            <div id="chatChoices" class="chat-choices"></div>
        </div>
    </div>

</body>

